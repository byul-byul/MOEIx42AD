# //.env.example — copy to .env and fill in values, never commit .env

# Postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=moei
POSTGRES_USER=moei
POSTGRES_PASSWORD=changeme

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# OpenAI
OPENAI_API_KEY=sk-...

# Telegram
TELEGRAM_BOT_TOKEN=...
TELEGRAM_WEBHOOK_URL=https://<ngrok-or-domain>/telegram/webhook

# Inter-service (override for local dev if not using Docker Compose)
BACKEND_URL=http://backend:8000

# Voice TTS voice ID (alloy | echo | fable | onyx | nova | shimmer)
TTS_VOICE=nova

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=...
WHATSAPP_PHONE_NUMBER_ID=...
WHATSAPP_VERIFY_TOKEN=...

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=...

# App
APP_ENV=development
LOG_LEVEL=INFO
