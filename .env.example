# //.env.example — copy to .env and fill in values, never commit .env

# Public URL (set automatically by make ngrok)
PUBLIC_BASE_URL=

# Postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=moei
POSTGRES_USER=moei
POSTGRES_PASSWORD=changeme

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Ngrok
NGROK_AUTH_TOKEN=

# Telegram
TELEGRAM_BOT_TOKEN=...
TELEGRAM_WEBHOOK_URL=   # Set automatically by `make cloudflare` (Cloudflare quick tunnel -> channels:8001)

# Inter-service (override for local dev if not using Docker Compose)
BACKEND_URL=http://backend:8000

# Voice TTS voice ID (alloy | echo | fable | onyx | nova | shimmer)
TTS_VOICE=nova

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=...

# App
APP_ENV=development
LOG_LEVEL=INFO
